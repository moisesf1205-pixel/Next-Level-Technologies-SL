# ========================================
# Configuración FTP para GoDaddy
# ========================================
# COPIA ESTE ARCHIVO A .env Y COMPLETA CON TUS DATOS

# Host FTP (ej: ftp.nextleveltechnologies.es)
FTP_HOST=ftp.tu_dominio.com

# Usuario FTP (puede ser email o usuario)
FTP_USER=usuario_ftp@ejemplo.com

# Contraseña FTP
FTP_PASSWORD=tu_contraseña_aqui

# Directorio remoto en el servidor
FTP_REMOTE_DIR=/public_html
